# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL ulanish URL (Supabase, Neon yoki o'zingizning serveringiz)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/clinic_db"

# ─── Next.js Auth ────────────────────────────────────────────────────────────
# Tasodifiy 32+ belgili matn. Ishlab chiqarish uchun: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Admin panel uchun JWT. Tasodifiy 32+ belgili matn.
JWT_SECRET="your-jwt-secret-key"
JWT_EXPIRES_IN="7d"

# ─── App URL ─────────────────────────────────────────────────────────────────
# Ishlab chiqarishda to'liq domen: https://yourdomain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# BotFather'dan olingan token: https://t.me/BotFather
TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"

# Webhook URL (faqat production'da, polling o'rniga)
TELEGRAM_WEBHOOK_URL="https://yourdomain.com/api/webhook/telegram"

# ─── Telegram WebApp ─────────────────────────────────────────────────────────
# WebApp ochilganda ko'rsatiladigan URL
NEXT_PUBLIC_WEBAPP_URL="https://yourdomain.com/webapp"

# WebApp'da ko'rsatiladigan klinika IDsi (bot botga bog'liq bo'lmagan holat uchun)
NEXT_PUBLIC_CLINIC_ID="your-clinic-cuid"

# ─── Bot klinikasi ────────────────────────────────────────────────────────────
# Bot xizmatlar ko'rsatadigan klinika IDsi (Prisma DB'dan)
DEFAULT_CLINIC_ID="your-clinic-cuid"

# ─── Timezone ────────────────────────────────────────────────────────────────
# Klinika joylashgan vaqt zonasi (IANA format)
# Misol: Asia/Tashkent, Europe/Moscow, Asia/Dubai
CLINIC_TIMEZONE="Asia/Tashkent"

# ─── Cron / Reminder ─────────────────────────────────────────────────────────
# POST /api/reminders so'rovlarini himoya qiluvchi maxfiy kalit
# Vercel Cron yoki tashqi cron xizmati ushbu kalitni Authorization headerida yuboradi
# Misol: Authorization: Bearer your-strong-cron-secret
# Yaratish: openssl rand -base64 32
CRON_SECRET="your-strong-cron-secret"
