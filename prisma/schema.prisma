generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum ServiceType {
  doctor_queue
  diagnostic
  home_service
}

enum AppointmentStatus {
  booked
  arrived
  missed
  cancelled
  expired
}

enum UserRole {
  super_admin
  clinic_admin
  branch_admin
  doctor
  receptionist
  patient
}

enum QueueMode {
  live
  online
  slot
}

enum SubscriptionPlan {
  starter
  standard
  premium
}

enum SubscriptionStatus {
  trial
  active
  past_due
  suspended
  cancelled
}

enum PaymentProvider {
  payme
  click
}

enum PaymentState {
  pending
  authorized
  paid
  cancelled
  failed
  refunded
  partial_refunded
}

enum RefundState {
  pending
  succeeded
  failed
}

enum AdChannelScope {
  clinic
  platform
}

enum PromotionType {
  aksiya
  yangilik
  elon
  umumiy
}

enum PromotionSource {
  kanal
  guruh
}

enum AdCampaignStatus {
  draft
  scheduled
  active
  completed
  cancelled
}

enum AdTargetType {
  own
  platform
}

// ─── CORE MODELS ─────────────────────────────────────────────────────────────

model Clinic {
  id          String    @id @default(cuid())
  name        String
  phone       String?
  address     String?
  logoUrl     String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ── Bosqich 1 faol maydonlar ──────────────────────────────────────────────
  description  String?  @db.Text
  city         String?
  workingHours String?
  rating       Float    @default(0) @db.Real
  ratingCount  Int      @default(0)

  // ── Telegram kanallar ─────────────────────────────────────────────────────
  telegramChannelUsername String?  // masalan "buyuktabib" (@ siz)
  telegramGroupUsername   String?  // public guruh username (@ siz)

  // ── Xodim limiti (superadmin belgilaydi, 0 = qo'shish o'chiq) ───────────
  maxEmployees Int @default(0)

  // ── Kelajak: Bosqich 2 (to'lov) va Bosqich 3 (abonement) ─────────────────
  paymentConfig         Json?             @db.JsonB
  subscriptionPlan      SubscriptionPlan  @default(starter)
  subscriptionStatus    SubscriptionStatus @default(trial)
  subscriptionExpiresAt DateTime?

  branches      Branch[]
  services      Service[]
  doctors       Doctor[]
  staff         Staff[]
  users         User[]
  appointments  Appointment[]
  slots         Slot[]
  settings      ClinicSettings?
  featureFlags  FeatureFlag[]
  moduleConfigs ModuleConfig[]
  userClinics   UserClinic[]
  payments      Payment[]
  adChannels    AdChannel[]
  adCampaigns   AdCampaign[]
  promotions    ClinicPromotion[]
  stints        EmploymentStint[]
  doctorRatings DoctorRating[]
  jobRequests   JobRequest[]
  showcaseBlocks ShowcaseBlock[]
  showcaseLimits ClinicShowcaseLimits?

  @@index([isActive, city])
  @@index([subscriptionStatus])
  @@map("clinics")
}

model Branch {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Bosqich 1 faol maydonlar ──────────────────────────────────────────────
  latitude     Float?  @db.DoublePrecision
  longitude    Float?  @db.DoublePrecision
  nearbyMetro  String?
  workingHours String?
  sortOrder    Int     @default(0)

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  admins       User[]
  doctors      Doctor[]
  staff        Staff[]
  appointments Appointment[]
  slots        Slot[]
  services     Service[]

  @@index([clinicId])
  @@index([clinicId, sortOrder])
  @@map("branches")
}

model Service {
  id                 String      @id @default(cuid())
  clinicId           String
  branchId           String?
  name               String
  type               ServiceType
  price              Decimal     @db.Decimal(10, 2)
  description        String?
  requiresSlot       Boolean     @default(false)
  requiresAddress    Boolean     @default(false)
  requiresPrePayment Boolean     @default(false)
  prePaymentAmount   Decimal?    @db.Decimal(12, 2)
  dailyLimit         Int?
  isActive           Boolean     @default(true)
  isHidden           Boolean     @default(false)
  sortOrder          Int         @default(0)
  defaultQueueMode   QueueMode   @default(online)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  clinic       Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch       Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  appointments Appointment[]
  slots        Slot[]
  doctors        ServiceDoctor[]
  showcaseBlocks ShowcaseBlock[]

  @@index([clinicId])
  @@index([clinicId, type])
  @@index([branchId])
  @@map("services")
}

model Doctor {
  id              String   @id @default(cuid())
  clinicId        String
  branchId        String?
  userId          String?
  employeeId      String?
  firstName       String
  lastName        String
  specialty       String
  phone           String?
  photoUrl        String?
  isActive        Boolean  @default(true)
  isHidden        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // FLIP-CARD-01 yangi maydonlar
  education       String?
  position        String?
  department      String?
  workSchedule    String?
  operationsCount Int      @default(0)
  bio             String?  @db.Text

  clinic          Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch          Branch?           @relation(fields: [branchId], references: [id])
  user            User?             @relation(fields: [userId], references: [id])
  employee        Employee?         @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  appointments    Appointment[]
  services        ServiceDoctor[]
  specialties     DoctorSpecialty[]
  directions      DoctorDirection[]
  experiences     DoctorExperience[]
  workplaces      DoctorWorkplace[]
  blockedDates    DoctorBlockedDate[]
  stints          EmploymentStint[]
  ratings         DoctorRating[]

  @@unique([userId, clinicId])
  @@index([clinicId])
  @@index([employeeId])
  @@map("doctors")
}

model DoctorBlockedDate {
  id        String   @id @default(cuid())
  doctorId  String
  type      String   // 'recurring' | 'once'
  weekday   Int?     // 0=Yakshanba ... 6=Shanba, recurring uchun
  date      String?  // 'YYYY-MM-DD', once uchun
  reason    String?
  createdBy String   // userId
  createdAt DateTime @default(now())

  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@map("doctor_blocked_dates")
}

model DoctorSpecialty {
  id         String    @id @default(cuid())
  doctorId   String
  employeeId String?
  name       String
  sortOrder  Int       @default(0)
  doctor     Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([employeeId])
  @@map("doctor_specialties")
}

model DoctorDirection {
  id         String    @id @default(cuid())
  doctorId   String
  employeeId String?
  name       String
  sortOrder  Int       @default(0)
  doctor     Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([employeeId])
  @@map("doctor_directions")
}

model DoctorExperience {
  id         String    @id @default(cuid())
  doctorId   String
  employeeId String?
  place      String
  startYear  Int
  endYear    Int?
  sortOrder  Int       @default(0)
  doctor     Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([employeeId])
  @@map("doctor_experiences")
}

model DoctorWorkplace {
  id         String    @id @default(cuid())
  doctorId   String
  employeeId String?
  place      String
  sortOrder  Int       @default(0)
  doctor     Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([employeeId])
  @@map("doctor_workplaces")
}

model ServiceDoctor {
  serviceId String
  doctorId  String
  queueMode QueueMode @default(online)
  createdAt DateTime  @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@id([serviceId, doctorId])
  @@index([doctorId])
  @@map("service_doctors")
}

model Staff {
  id         String   @id @default(cuid())
  clinicId   String
  branchId   String?
  userId     String?
  employeeId String?
  firstName  String
  lastName   String
  role       UserRole @default(receptionist)
  phone      String?
  photoUrl   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  clinic               Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch               Branch?       @relation(fields: [branchId], references: [id])
  user                 User?         @relation(fields: [userId], references: [id])
  employee             Employee?     @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  assignedAppointments Appointment[] @relation("AssignedStaff")
  stints               EmploymentStint[]

  @@unique([userId, clinicId])
  @@index([clinicId])
  @@index([employeeId])
  @@map("staff")
}

model Employee {
  id             String   @id @default(cuid())
  emId           String   @unique
  firstName      String
  lastName       String?
  phone          String?
  profession     String?
  userId         String?  @unique
  maxJobRequests Int      @default(1)
  maxClinics     Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Portativ profil maydonlari (EM_ID'ga tegishli, klinikaga emas)
  photoUrl        String?
  specialty       String?
  education       String?
  position        String?
  department      String?
  bio             String?  @db.Text
  workSchedule    String?
  operationsCount Int?

  compositeRating     Decimal?  @db.Decimal(3, 2)
  ratingCount         Int       @default(0)
  ratingPatientScore  Decimal?  @db.Decimal(3, 2)
  ratingReturnRate    Decimal?  @db.Decimal(4, 3)
  ratingArrivedRate   Decimal?  @db.Decimal(4, 3)
  ratingActivityScore Decimal?  @db.Decimal(4, 3)
  ratingLastUpdatedAt DateTime?

  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  staff       Staff[]
  doctors     Doctor[]
  stints      EmploymentStint[]
  ratings     DoctorRating[]
  specialties DoctorSpecialty[]
  directions  DoctorDirection[]
  experiences DoctorExperience[]
  workplaces  DoctorWorkplace[]
  jobRequests    JobRequest[]
  showcaseBlocks ShowcaseBlock[]

  @@map("employees")
}

model JobRequest {
  id          String    @id @default(cuid())
  employeeId  String
  clinicId    String
  role        String    @default("doctor")
  status      String    @default("pending")
  initiatedBy String    @default("employee")   // 'employee' | 'clinic'
  message     String?
  decidedBy   String?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clinic      Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  // Partial unique (pending) — DB'da qo'lda yaratilgan (uq_jobreq_pending), Prisma'da @@unique yo'q
  @@index([clinicId])
  @@index([employeeId])
  @@map("job_requests")
}

model User {
  id           String   @id @default(cuid())
  clinicId     String?
  branchId     String?
  telegramId   String?  @unique
  tibId        String?  @unique
  phone        String?  @unique
  username     String?  @unique
  firstName    String
  lastName     String?
  fatherName   String?
  region       String?
  district     String?
  role           UserRole @default(patient)
  onboardingStep String?  // null | "contact" | "profile" | "done"
  passwordHash   String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinic             Clinic?             @relation(fields: [clinicId], references: [id])
  branch             Branch?             @relation(fields: [branchId], references: [id])
  doctors            Doctor[]
  staffRecords       Staff[]
  employee           Employee?
  appointments       Appointment[]
  telegramIdHistory  TelegramIdHistory[]
  userClinics        UserClinic[]
  payments           Payment[]
  dependents         Dependent[]
  relayLogs          TelegramRelayLog[] @relation("StaffRelayLog")
  doctorRatings      DoctorRating[]

  @@index([clinicId])
  @@index([branchId])
  @@index([telegramId])
  @@index([username])
  @@map("users")
}

model Dependent {
  id        String    @id @default(cuid())
  userId    String
  firstName String
  lastName  String?
  phone     String?
  relation  String?
  birthYear Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([userId])
  @@index([userId, deletedAt])
  @@map("dependents")
}

model UserClinic {
  id             String    @id @default(cuid())
  userId         String
  clinicId       String
  role           UserRole  @default(patient)
  joinedAt       DateTime  @default(now())
  isActive       Boolean   @default(true)
  isCurrent      Boolean   @default(false)
  lastSelectedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId])
  @@index([userId])
  @@index([clinicId])
  @@index([userId, isCurrent])
  @@map("user_clinics")
}

model Appointment {
  id          String            @id @default(cuid())
  clinicId    String
  branchId    String?
  serviceId   String
  doctorId    String?
  userId      String?
  slotId      String?
  staffId     String?

  patientName  String
  patientPhone String
  address      String?
  queueNumber  Int?
  date         DateTime          @db.Date
  status       AppointmentStatus @default(booked)
  notes        String?
  notifiedDayBefore Boolean      @default(false)
  notifiedTwoHours  Boolean      @default(false)
  locationLat        Float?
  locationLng        Float?
  locationLivePeriod Int?
  locationSharedAt   DateTime?   @db.Timestamp(6)
  liveLat            Float?
  liveLng            Float?
  liveStartedAt      DateTime?   @db.Timestamp(6)
  liveExpiresAt      DateTime?   @db.Timestamp(6)
  liveLastUpdatedAt  DateTime?   @db.Timestamp(6)
  liveMessageId      BigInt?
  liveStatus         String?
  queueMode    QueueMode         @default(online)
  paymentStatus String           @default("pending")
  paidAmount             Int?
  appliedDiscountPercent Int      @default(0)
  paidAt                 DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  dependentId  String?
  arrivedAt    DateTime?
  cancelledBy  String?

  clinic        Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch        Branch?    @relation(fields: [branchId], references: [id])
  service       Service    @relation(fields: [serviceId], references: [id])
  doctor        Doctor?    @relation(fields: [doctorId], references: [id])
  user          User?      @relation(fields: [userId], references: [id])
  slot          Slot?      @relation(fields: [slotId], references: [id])
  assignedStaff Staff?     @relation("AssignedStaff", fields: [staffId], references: [id])
  dependent     Dependent? @relation(fields: [dependentId], references: [id], onDelete: SetNull)
  payments      Payment[]
  relayLogs     TelegramRelayLog[]
  rating        DoctorRating?

  @@index([clinicId])
  @@index([clinicId, date])
  @@index([doctorId, date])
  @@index([serviceId, date])
  @@index([userId, clinicId, status])
  @@index([dependentId, clinicId, status])
  @@index([date, status])
  @@index([liveStatus, liveExpiresAt], map: "appointments_live_active_idx")
  @@map("appointments")
}

model Slot {
  id        String   @id @default(cuid())
  clinicId  String
  branchId  String?
  serviceId String
  date      DateTime @db.Date
  startTime String
  endTime   String
  capacity  Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch       Branch?       @relation(fields: [branchId], references: [id])
  service      Service       @relation(fields: [serviceId], references: [id])
  appointments Appointment[]

  @@index([clinicId, serviceId, date])
  @@map("slots")
}

// ─── SUPERADMIN MODELS ────────────────────────────────────────────────────────

model ClinicSettings {
  id                String   @id @default(cuid())
  clinicId          String   @unique
  dailyLimit        Int      @default(40)
  timezone          String   @default("Asia/Tashkent")
  bookingWindowDays Int      @default(7)
  allowSameDay      Boolean  @default(true)
  enableQueue       Boolean  @default(true)
  enableSlots       Boolean  @default(true)
  enableHomeService Boolean  @default(false)
  enableWebapp      Boolean  @default(true)
  enableBot         Boolean  @default(true)
  is24Hours         Boolean  @default(false)
  holidays          Json     @default("[]") @db.JsonB
  patientSelfLimit      Int      @default(4)
  dependentBookingLimit Int      @default(1)
  maxDependents         Int      @default(2)
  discountPercent       Int      @default(0)
  showRatingCount       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_settings")
}

model FeatureFlag {
  id        String   @id @default(cuid())
  clinicId  String
  key       String
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, key])
  @@index([clinicId])
  @@map("feature_flags")
}

model ModuleConfig {
  id        String      @id @default(cuid())
  clinicId  String
  module    ServiceType
  enabled   Boolean     @default(true)
  config    Json        @default("{}")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, module])
  @@index([clinicId])
  @@map("module_configs")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  clinicId  String?
  action    String
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([clinicId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

model TelegramIdHistory {
  id            Int      @id @default(autoincrement())
  userId        String
  tibId         String
  oldTelegramId String?
  newTelegramId String
  reason        String?
  changedAt     DateTime @default(now()) @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tibId])
  @@map("telegram_id_history")
}

// ─── PAYMENT MODELS ───────────────────────────────────────────────────────────

model Payment {
  id            String          @id @default(cuid())

  appointmentId String
  appointment   Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  clinicId      String
  clinic        Clinic          @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  userId        String?
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  provider      PaymentProvider
  providerTxId  String?
  amount        BigInt
  currency      String          @default("UZS")
  state         PaymentState    @default(pending)

  rawCallback   Json?
  rawCreate     Json?
  errorCode     String?
  errorMessage  String?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  authorizedAt  DateTime?
  paidAt        DateTime?
  cancelledAt   DateTime?

  refunds       Refund[]

  @@unique([provider, providerTxId], name: "provider_tx_unique")
  @@index([appointmentId])
  @@index([clinicId, state])
  @@index([state, createdAt])
  @@map("payments")
}

model Refund {
  id              String      @id @default(cuid())
  paymentId       String
  payment         Payment     @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  amount          BigInt
  reason          String?
  state           RefundState @default(pending)
  providerRefundId String?
  rawCallback     Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([paymentId])
  @@map("refunds")
}

model BotState {
  telegramId String   @id
  step       String
  data       Json     @default("{}")
  expiresAt  DateTime @default(dbgenerated("(now() + interval '30 minutes')")) @db.Timestamp(6)
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  updatedAt  DateTime @default(now()) @db.Timestamp(6)

  @@index([expiresAt])
  @@map("bot_states")
}

model TelegramRelayLog {
  id                String   @id @default(cuid())
  appointmentId     String?
  staffUserId       String?
  patientTelegramId String
  patientName       String?

  /// 'message' | 'photo' | 'document'
  kind              String   @default("message")

  fileName          String?
  fileSize          Int?
  mimeType          String?
  caption           String?  @db.Text

  tgMessageId       Int?
  success           Boolean  @default(false)
  errorMessage      String?

  openedAt          DateTime @default(now())
  ip                String?
  userAgent         String?  @db.Text

  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  staff       User?        @relation("StaffRelayLog", fields: [staffUserId], references: [id], onDelete: SetNull)

  @@index([staffUserId])
  @@index([appointmentId])
  @@index([openedAt(sort: Desc)])
  @@index([kind])
  @@map("telegram_relay_log")
}

// ─── AD BROADCAST MODELS ──────────────────────────────────────────────────────

model AdChannel {
  id          String         @id @default(cuid())
  title       String
  chatId      String         @unique
  type        String
  username    String?
  memberCount Int?

  scope       AdChannelScope @default(clinic)
  clinicId    String?
  addedById   String

  isActive    Boolean        @default(true)
  addedAt     DateTime       @default(now())

  clinic      Clinic?        @relation(fields: [clinicId], references: [id])
  posts       AdPost[]
  campaigns   AdCampaignChannel[]

  @@index([scope])
  @@index([clinicId])
  @@map("ad_channels")
}

model AdCampaign {
  id          String           @id @default(cuid())
  clinicId    String
  title       String
  adText      String           @db.Text
  imageUrl    String?
  buttonText  String?
  buttonUrl   String?

  targetType  AdTargetType     @default(own)

  startDate   DateTime
  endDate     DateTime
  frequency   String           @default("daily")

  status      AdCampaignStatus @default(scheduled)
  priority    Int              @default(0)

  createdById String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  clinic      Clinic           @relation(fields: [clinicId], references: [id])
  posts       AdPost[]
  channels    AdCampaignChannel[]

  @@index([clinicId])
  @@index([status, startDate])
  @@index([targetType, status])
  @@map("ad_campaigns")
}

model AdCampaignChannel {
  id         String     @id @default(cuid())
  campaignId String
  channelId  String

  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel    AdChannel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([campaignId, channelId])
  @@map("ad_campaign_channels")
}

model AdPost {
  id         String     @id @default(cuid())
  campaignId String
  channelId  String
  messageId  String?
  status     String
  errorText  String?
  sentAt     DateTime   @default(now())

  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel    AdChannel  @relation(fields: [channelId], references: [id])

  @@index([campaignId])
  @@index([sentAt])
  @@map("ad_posts")
}

model ClinicPromotion {
  id                  String          @id @default(cuid())
  clinicId            String
  clinic              Clinic          @relation(fields: [clinicId], references: [id])
  postUrl             String
  embedId             String          // "kanal/123" — telegram-widget.js uchun
  type                PromotionType   @default(umumiy)
  source              PromotionSource @default(kanal)
  title               String?
  subscribeUsername   String?
  showSubscribeButton Boolean         @default(true)
  isActive            Boolean         @default(true)
  sortOrder           Int             @default(0)
  publishedAt         DateTime        @default(now())
  createdById         String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([clinicId, isActive])
  @@map("clinic_promotions")
}

model RateLimit {
  key         String @id
  count       Int
  windowStart BigInt
  windowMs    BigInt

  @@map("rate_limits")
}

// ─── SHIFOKOR TITUL MODELLARI ─────────────────────────────────────────────────

model EmploymentStint {
  id         String    @id @default(cuid())
  employeeId String
  clinicId   String
  doctorId   String?
  staffId    String?
  role       String
  startDate  DateTime
  endDate    DateTime?
  endReason  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
  clinic   Clinic   @relation(fields: [clinicId], references: [id])
  doctor   Doctor?  @relation(fields: [doctorId], references: [id])
  staffRec Staff?   @relation(fields: [staffId], references: [id])

  @@index([employeeId])
  @@index([clinicId])
  @@map("employment_stints")
}

model DoctorRating {
  id            String   @id @default(cuid())
  employeeId    String
  doctorId      String?
  clinicId      String
  appointmentId String   @unique
  userId        String?
  telegramId    String?
  dependentId   String?
  stars         Decimal  @db.Decimal(2, 1)
  comment       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  employee    Employee    @relation(fields: [employeeId], references: [id])
  doctor      Doctor?     @relation(fields: [doctorId], references: [id])
  clinic      Clinic      @relation(fields: [clinicId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])
  user        User?       @relation(fields: [userId], references: [id])

  @@index([employeeId])
  @@index([clinicId])
  @@index([userId])
  @@index([createdAt])
  @@map("doctor_ratings")
}

model GlobalSetting {
  key       String   @id
  value     Json     @db.JsonB
  updatedAt DateTime @default(now()) @updatedAt

  @@map("global_settings")
}

// ─── SHOWCASE (REKLAMA VITRINA) MODELLARI ────────────────────────────────────

enum ShowcaseTab {
  doctors
  services
}

enum ShowcaseSource {
  em
  service
  manual
}

enum ShowcaseCta {
  auto
  generic
  none
}

enum ShowcaseMediaKind {
  image
  gif
  video
  audio
  youtube
  telegram
  pdf
}

enum ShowcaseMediaSource {
  upload
  url
}

enum ShowcaseShape {
  original
  circle
}

model ShowcaseBlock {
  id         String         @id @default(cuid())
  clinicId   String
  tab        ShowcaseTab
  sortOrder  Int            @default(0)
  source     ShowcaseSource @default(manual)
  employeeId String?
  serviceId  String?
  title      String
  subtitle   String?
  showRating Boolean        @default(true)
  cta        ShowcaseCta    @default(auto)
  isActive   Boolean        @default(true)
  createdBy  String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?

  clinic   Clinic          @relation(fields: [clinicId],   references: [id], onDelete: Cascade)
  employee Employee?       @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  service  Service?        @relation(fields: [serviceId],  references: [id], onDelete: SetNull)
  media    ShowcaseMedia[]

  @@index([clinicId, tab, sortOrder])
  @@index([employeeId])
  @@index([serviceId])
  @@map("showcase_blocks")
}

model ShowcaseMedia {
  id                String              @id @default(cuid())
  blockId           String
  sortOrder         Int                 @default(0)
  kind              ShowcaseMediaKind
  mediaSource       ShowcaseMediaSource
  storagePath       String?
  url               String?
  embedRef          String?
  posterStoragePath String?
  posterUrl         String?
  shape             ShowcaseShape       @default(original)
  aspectW           Int?
  aspectH           Int?
  title             String?
  caption           String?
  mimeType          String?
  fileSizeBytes     Int?
  durationSec       Int?
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  block ShowcaseBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId, sortOrder])
  @@map("showcase_media")
}

model ClinicShowcaseLimits {
  id                String   @id @default(cuid())
  clinicId          String   @unique
  maxBlocksDoctors  Int      @default(0)
  maxBlocksServices Int      @default(0)
  maxMediaPerBlock  Int      @default(0)
  maxImageKb        Int      @default(0)
  maxGifKb          Int      @default(0)
  maxVideoKb        Int      @default(0)
  maxAudioKb        Int      @default(0)
  maxPdfKb          Int      @default(0)
  storageTotalMb    Int      @default(0)
  videoMaxSec       Int      @default(0)
  allowVideoUpload  Boolean  @default(false)
  allowedFormats    Json     @default("[\"image\",\"gif\",\"youtube\",\"telegram\",\"pdf\",\"audio\",\"url\"]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_showcase_limits")
}
