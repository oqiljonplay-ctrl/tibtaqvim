generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum ServiceType {
  doctor_queue
  diagnostic
  home_service
}

enum AppointmentStatus {
  booked
  arrived
  missed
  cancelled
}

enum UserRole {
  super_admin
  clinic_admin
  branch_admin
  doctor
  receptionist
  patient
}

enum QueueMode {
  live
  online
  slot
}

enum SubscriptionPlan {
  starter
  standard
  premium
}

enum SubscriptionStatus {
  trial
  active
  past_due
  suspended
  cancelled
}

enum PaymentProvider {
  payme
  click
}

enum PaymentState {
  pending
  authorized
  paid
  cancelled
  failed
  refunded
  partial_refunded
}

enum RefundState {
  pending
  succeeded
  failed
}

enum AdChannelScope {
  clinic
  platform
}

enum PromotionType {
  aksiya
  yangilik
  elon
  umumiy
}

enum PromotionSource {
  kanal
  guruh
}

enum AdCampaignStatus {
  draft
  scheduled
  active
  completed
  cancelled
}

enum AdTargetType {
  own
  platform
}

// ─── CORE MODELS ─────────────────────────────────────────────────────────────

model Clinic {
  id          String    @id @default(cuid())
  name        String
  phone       String?
  address     String?
  logoUrl     String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ── Bosqich 1 faol maydonlar ──────────────────────────────────────────────
  description  String?  @db.Text
  city         String?
  workingHours String?
  rating       Float    @default(0) @db.Real
  ratingCount  Int      @default(0)

  // ── Telegram kanallar ─────────────────────────────────────────────────────
  telegramChannelUsername String?  // masalan "buyuktabib" (@ siz)
  telegramGroupUsername   String?  // public guruh username (@ siz)

  // ── Kelajak: Bosqich 2 (to'lov) va Bosqich 3 (abonement) ─────────────────
  paymentConfig         Json?             @db.JsonB
  subscriptionPlan      SubscriptionPlan  @default(starter)
  subscriptionStatus    SubscriptionStatus @default(trial)
  subscriptionExpiresAt DateTime?

  branches      Branch[]
  services      Service[]
  doctors       Doctor[]
  staff         Staff[]
  users         User[]
  appointments  Appointment[]
  slots         Slot[]
  settings      ClinicSettings?
  featureFlags  FeatureFlag[]
  moduleConfigs ModuleConfig[]
  userClinics   UserClinic[]
  payments      Payment[]
  adChannels    AdChannel[]
  adCampaigns   AdCampaign[]
  promotions    ClinicPromotion[]

  @@index([isActive, city])
  @@index([subscriptionStatus])
  @@map("clinics")
}

model Branch {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Bosqich 1 faol maydonlar ──────────────────────────────────────────────
  latitude     Float?  @db.DoublePrecision
  longitude    Float?  @db.DoublePrecision
  nearbyMetro  String?
  workingHours String?
  sortOrder    Int     @default(0)

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  admins       User[]
  doctors      Doctor[]
  staff        Staff[]
  appointments Appointment[]
  slots        Slot[]
  services     Service[]

  @@index([clinicId])
  @@index([clinicId, sortOrder])
  @@map("branches")
}

model Service {
  id                 String      @id @default(cuid())
  clinicId           String
  branchId           String?
  name               String
  type               ServiceType
  price              Decimal     @db.Decimal(10, 2)
  description        String?
  requiresSlot       Boolean     @default(false)
  requiresAddress    Boolean     @default(false)
  requiresPrePayment Boolean     @default(false)
  prePaymentAmount   Decimal?    @db.Decimal(12, 2)
  dailyLimit         Int?
  isActive           Boolean     @default(true)
  sortOrder          Int         @default(0)
  defaultQueueMode   QueueMode   @default(online)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  clinic       Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch       Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  appointments Appointment[]
  slots        Slot[]
  doctors      ServiceDoctor[]

  @@index([clinicId])
  @@index([clinicId, type])
  @@index([branchId])
  @@map("services")
}

model Doctor {
  id              String   @id @default(cuid())
  clinicId        String
  branchId        String?
  userId          String?  @unique
  firstName       String
  lastName        String
  specialty       String
  phone           String?
  photoUrl        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // FLIP-CARD-01 yangi maydonlar
  education       String?
  position        String?
  department      String?
  workSchedule    String?
  operationsCount Int      @default(0)
  bio             String?  @db.Text

  clinic          Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch          Branch?           @relation(fields: [branchId], references: [id])
  user            User?             @relation(fields: [userId], references: [id])
  appointments    Appointment[]
  services        ServiceDoctor[]
  specialties     DoctorSpecialty[]
  directions      DoctorDirection[]
  experiences     DoctorExperience[]
  workplaces      DoctorWorkplace[]

  @@index([clinicId])
  @@map("doctors")
}

model DoctorSpecialty {
  id        String  @id @default(cuid())
  doctorId  String
  name      String
  sortOrder Int     @default(0)
  doctor    Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@map("doctor_specialties")
}

model DoctorDirection {
  id        String  @id @default(cuid())
  doctorId  String
  name      String
  sortOrder Int     @default(0)
  doctor    Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@map("doctor_directions")
}

model DoctorExperience {
  id        String  @id @default(cuid())
  doctorId  String
  place     String
  startYear Int
  endYear   Int?
  sortOrder Int     @default(0)
  doctor    Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@map("doctor_experiences")
}

model DoctorWorkplace {
  id        String  @id @default(cuid())
  doctorId  String
  place     String
  sortOrder Int     @default(0)
  doctor    Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@map("doctor_workplaces")
}

model ServiceDoctor {
  serviceId String
  doctorId  String
  queueMode QueueMode @default(online)
  createdAt DateTime  @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@id([serviceId, doctorId])
  @@index([doctorId])
  @@map("service_doctors")
}

model Staff {
  id         String   @id @default(cuid())
  clinicId   String
  branchId   String?
  userId     String?  @unique
  firstName  String
  lastName   String
  role       UserRole @default(receptionist)
  phone      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  clinic               Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch               Branch?       @relation(fields: [branchId], references: [id])
  user                 User?         @relation(fields: [userId], references: [id])
  assignedAppointments Appointment[] @relation("AssignedStaff")

  @@index([clinicId])
  @@map("staff")
}

model User {
  id           String   @id @default(cuid())
  clinicId     String?
  branchId     String?
  telegramId   String?  @unique
  tibId        String?  @unique
  phone        String?  @unique
  username     String?  @unique
  firstName    String
  lastName     String?
  fatherName   String?
  region       String?
  district     String?
  role         UserRole @default(patient)
  passwordHash String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic             Clinic?             @relation(fields: [clinicId], references: [id])
  branch             Branch?             @relation(fields: [branchId], references: [id])
  doctor             Doctor?
  staff              Staff?
  appointments       Appointment[]
  telegramIdHistory  TelegramIdHistory[]
  userClinics        UserClinic[]
  payments           Payment[]
  dependents         Dependent[]
  relayLogs          TelegramRelayLog[] @relation("StaffRelayLog")

  @@index([clinicId])
  @@index([branchId])
  @@index([telegramId])
  @@index([username])
  @@map("users")
}

model Dependent {
  id        String    @id @default(cuid())
  userId    String
  firstName String
  lastName  String?
  phone     String?
  relation  String?
  birthYear Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, deletedAt])
  @@map("dependents")
}

model UserClinic {
  id             String    @id @default(cuid())
  userId         String
  clinicId       String
  role           UserRole  @default(patient)
  joinedAt       DateTime  @default(now())
  isActive       Boolean   @default(true)
  isCurrent      Boolean   @default(false)
  lastSelectedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId])
  @@index([userId])
  @@index([clinicId])
  @@index([userId, isCurrent])
  @@map("user_clinics")
}

model Appointment {
  id          String            @id @default(cuid())
  clinicId    String
  branchId    String?
  serviceId   String
  doctorId    String?
  userId      String?
  slotId      String?
  staffId     String?

  patientName  String
  patientPhone String
  address      String?
  queueNumber  Int?
  date         DateTime          @db.Date
  status       AppointmentStatus @default(booked)
  notes        String?
  notifiedDayBefore Boolean      @default(false)
  notifiedTwoHours  Boolean      @default(false)
  locationLat        Float?
  locationLng        Float?
  locationLivePeriod Int?
  locationSharedAt   DateTime?   @db.Timestamp(6)
  liveLat            Float?
  liveLng            Float?
  liveStartedAt      DateTime?   @db.Timestamp(6)
  liveExpiresAt      DateTime?   @db.Timestamp(6)
  liveLastUpdatedAt  DateTime?   @db.Timestamp(6)
  liveMessageId      BigInt?
  liveStatus         String?
  queueMode    QueueMode         @default(online)
  paymentStatus String           @default("pending")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  clinic        Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch        Branch?  @relation(fields: [branchId], references: [id])
  service       Service  @relation(fields: [serviceId], references: [id])
  doctor        Doctor?  @relation(fields: [doctorId], references: [id])
  user          User?    @relation(fields: [userId], references: [id])
  slot          Slot?    @relation(fields: [slotId], references: [id])
  assignedStaff Staff?   @relation("AssignedStaff", fields: [staffId], references: [id])
  payments      Payment[]
  relayLogs     TelegramRelayLog[]

  @@index([clinicId])
  @@index([clinicId, date])
  @@index([doctorId, date])
  @@index([serviceId, date])
  @@index([liveStatus, liveExpiresAt], map: "appointments_live_active_idx")
  @@map("appointments")
}

model Slot {
  id        String   @id @default(cuid())
  clinicId  String
  branchId  String?
  serviceId String
  date      DateTime @db.Date
  startTime String
  endTime   String
  capacity  Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branch       Branch?       @relation(fields: [branchId], references: [id])
  service      Service       @relation(fields: [serviceId], references: [id])
  appointments Appointment[]

  @@index([clinicId, serviceId, date])
  @@map("slots")
}

// ─── SUPERADMIN MODELS ────────────────────────────────────────────────────────

model ClinicSettings {
  id                String   @id @default(cuid())
  clinicId          String   @unique
  dailyLimit        Int      @default(40)
  timezone          String   @default("Asia/Tashkent")
  bookingWindowDays Int      @default(7)
  allowSameDay      Boolean  @default(true)
  enableQueue       Boolean  @default(true)
  enableSlots       Boolean  @default(true)
  enableHomeService Boolean  @default(false)
  enableWebapp      Boolean  @default(true)
  enableBot         Boolean  @default(true)
  is24Hours         Boolean  @default(false)
  holidays          Json     @default("[]") @db.JsonB
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_settings")
}

model FeatureFlag {
  id        String   @id @default(cuid())
  clinicId  String
  key       String
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, key])
  @@index([clinicId])
  @@map("feature_flags")
}

model ModuleConfig {
  id        String      @id @default(cuid())
  clinicId  String
  module    ServiceType
  enabled   Boolean     @default(true)
  config    Json        @default("{}")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, module])
  @@index([clinicId])
  @@map("module_configs")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  clinicId  String?
  action    String
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([clinicId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

model TelegramIdHistory {
  id            Int      @id @default(autoincrement())
  userId        String
  tibId         String
  oldTelegramId String?
  newTelegramId String
  reason        String?
  changedAt     DateTime @default(now()) @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tibId])
  @@map("telegram_id_history")
}

// ─── PAYMENT MODELS ───────────────────────────────────────────────────────────

model Payment {
  id            String          @id @default(cuid())

  appointmentId String
  appointment   Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  clinicId      String
  clinic        Clinic          @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  userId        String?
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  provider      PaymentProvider
  providerTxId  String?
  amount        BigInt
  currency      String          @default("UZS")
  state         PaymentState    @default(pending)

  rawCallback   Json?
  rawCreate     Json?
  errorCode     String?
  errorMessage  String?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  authorizedAt  DateTime?
  paidAt        DateTime?
  cancelledAt   DateTime?

  refunds       Refund[]

  @@unique([provider, providerTxId], name: "provider_tx_unique")
  @@index([appointmentId])
  @@index([clinicId, state])
  @@index([state, createdAt])
  @@map("payments")
}

model Refund {
  id              String      @id @default(cuid())
  paymentId       String
  payment         Payment     @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  amount          BigInt
  reason          String?
  state           RefundState @default(pending)
  providerRefundId String?
  rawCallback     Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([paymentId])
  @@map("refunds")
}

model BotState {
  telegramId String   @id
  step       String
  data       Json     @default("{}")
  expiresAt  DateTime @default(dbgenerated("(now() + interval '30 minutes')")) @db.Timestamp(6)
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  updatedAt  DateTime @default(now()) @db.Timestamp(6)

  @@index([expiresAt])
  @@map("bot_states")
}

model TelegramRelayLog {
  id                String   @id @default(cuid())
  appointmentId     String?
  staffUserId       String?
  patientTelegramId String
  patientName       String?

  /// 'message' | 'photo' | 'document'
  kind              String   @default("message")

  fileName          String?
  fileSize          Int?
  mimeType          String?
  caption           String?  @db.Text

  tgMessageId       Int?
  success           Boolean  @default(false)
  errorMessage      String?

  openedAt          DateTime @default(now())
  ip                String?
  userAgent         String?  @db.Text

  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  staff       User?        @relation("StaffRelayLog", fields: [staffUserId], references: [id], onDelete: SetNull)

  @@index([staffUserId])
  @@index([appointmentId])
  @@index([openedAt(sort: Desc)])
  @@index([kind])
  @@map("telegram_relay_log")
}

// ─── AD BROADCAST MODELS ──────────────────────────────────────────────────────

model AdChannel {
  id          String         @id @default(cuid())
  title       String
  chatId      String         @unique
  type        String
  username    String?
  memberCount Int?

  scope       AdChannelScope @default(clinic)
  clinicId    String?
  addedById   String

  isActive    Boolean        @default(true)
  addedAt     DateTime       @default(now())

  clinic      Clinic?        @relation(fields: [clinicId], references: [id])
  posts       AdPost[]
  campaigns   AdCampaignChannel[]

  @@index([scope])
  @@index([clinicId])
  @@map("ad_channels")
}

model AdCampaign {
  id          String           @id @default(cuid())
  clinicId    String
  title       String
  adText      String           @db.Text
  imageUrl    String?
  buttonText  String?
  buttonUrl   String?

  targetType  AdTargetType     @default(own)

  startDate   DateTime
  endDate     DateTime
  frequency   String           @default("daily")

  status      AdCampaignStatus @default(scheduled)
  priority    Int              @default(0)

  createdById String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  clinic      Clinic           @relation(fields: [clinicId], references: [id])
  posts       AdPost[]
  channels    AdCampaignChannel[]

  @@index([clinicId])
  @@index([status, startDate])
  @@index([targetType, status])
  @@map("ad_campaigns")
}

model AdCampaignChannel {
  id         String     @id @default(cuid())
  campaignId String
  channelId  String

  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel    AdChannel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([campaignId, channelId])
  @@map("ad_campaign_channels")
}

model AdPost {
  id         String     @id @default(cuid())
  campaignId String
  channelId  String
  messageId  String?
  status     String
  errorText  String?
  sentAt     DateTime   @default(now())

  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel    AdChannel  @relation(fields: [channelId], references: [id])

  @@index([campaignId])
  @@index([sentAt])
  @@map("ad_posts")
}

model ClinicPromotion {
  id                  String          @id @default(cuid())
  clinicId            String
  clinic              Clinic          @relation(fields: [clinicId], references: [id])
  postUrl             String
  embedId             String          // "kanal/123" — telegram-widget.js uchun
  type                PromotionType   @default(umumiy)
  source              PromotionSource @default(kanal)
  title               String?
  subscribeUsername   String?
  showSubscribeButton Boolean         @default(true)
  isActive            Boolean         @default(true)
  sortOrder           Int             @default(0)
  publishedAt         DateTime        @default(now())
  createdById         String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([clinicId, isActive])
  @@map("clinic_promotions")
}
